# LockdIN web — environment variables
# Copy to `.env` and fill in. All client-exposed vars MUST be prefixed VITE_.

# Base URL for the FastAPI backend. Default "/api" works with the Vite dev proxy
# (see vite.config.ts) and with same-origin production deployments.
VITE_API_BASE=/api

# Supabase project (reused from the existing frontend/js/supabase-client.js).
VITE_SUPABASE_URL=https://pgrtaxjxmngwjmrzfbrc.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBncnRheGp4bW5nd2ptcnpmYnJjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEwODMwMDksImV4cCI6MjA4NjY1OTAwOX0.k7x7Ku5gn4a2U6rQhAQT6OrA2t2s0l5kem6U3UfeUiM

# OneSignal Web Push app id (public — safe to ship to the client). Must match the
# backend's ONESIGNAL_APP_ID. The backend sends pushes targeted by external_id =
# the Supabase user id; this frontend subscribes the browser and calls
# OneSignal.login(userId) so those pushes land. If unset, push is a silent no-op
# (the rest of the app works), so it's safe to leave blank in dev.
VITE_ONESIGNAL_APP_ID=31f01132-0585-412a-8b2b-36e7f361309d
